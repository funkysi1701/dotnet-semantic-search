@page "/"
@using System.Net.Http.Json
@using System.Text.Encodings.Web
@inject HttpClient Http
@inject IConfiguration Configuration

<PageTitle>@_homePageTitle</PageTitle>
<HeadContent>
    <meta name="description" content="@_homeMetaDescription" />
    <link rel="canonical" href="@_canonicalHomeUrl" />
    <meta property="og:title" content="@_homePageTitle" />
    <meta property="og:description" content="@_homeMetaDescription" />
    <meta property="og:url" content="@_canonicalHomeUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:image" content="@_shareImageUrl" />
    <meta property="og:image:alt" content="@_shareImageAlt" />
    <meta property="og:locale" content="en_GB" />
    <meta property="og:site_name" content="@_siteName" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@_homePageTitle" />
    <meta name="twitter:description" content="@_homeMetaDescription" />
    <meta name="twitter:image" content="@_shareImageUrl" />
    <meta name="twitter:image:alt" content="@_shareImageAlt" />
    <script type="application/ld+json">@((MarkupString)_jsonLd)</script>
</HeadContent>

<main class="page">
    <header class="hero">
        <p class="hero__eyebrow">Blog search</p>
        <h1 class="hero__title">
            Find anything on <a class="hero__site" href="https://www.funkysi1701.com/" target="_blank" rel="noopener noreferrer">funkysi1701.com</a>
        </h1>
        <p class="hero__lede">
            Ask in your own words — this search matches <em>meaning</em>, not just exact keywords, so you can discover posts even when you do not remember the title.
        </p>
    </header>

    <section class="search" aria-label="Search funkysi1701.com">
        <form class="search__form" @onsubmit="SearchAsync" @onsubmit:preventDefault="true">
            <label class="search__label" for="q">What are you looking for?</label>
            <div class="search__row">
                <input id="q"
                       @ref="_queryInput"
                       class="search__input"
                       @bind="query"
                       @bind:event="oninput"
                       autocomplete="off"
                       maxlength="500"
                       placeholder="e.g. Azure tips, C# performance, conference talks…"
                       disabled="@isLoading" />
                <button class="search__submit" type="submit" disabled="@isLoading">
                    @(isLoading ? "Searching…" : "Search")
                </button>
            </div>
        </form>
    </section>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <p class="message message--error" role="alert">@errorMessage</p>
    }

    @if (isLoading)
    {
        <div class="search-loading" role="status" aria-live="polite">
            <span class="search-loading__spinner" aria-hidden="true"></span>
            <span class="search-loading__text">Fetching results…</span>
        </div>
    }

    @if (results.Count > 0)
    {
        <section class="results" aria-label="Search results">
            <h2 class="results__title">@results.Count post@(results.Count == 1 ? "" : "s") that fit what you asked</h2>
            <ul class="results__cards">
                @foreach (var item in results)
                {
                    <li class="results__card">
                        <a class="results__card-link @(string.IsNullOrWhiteSpace(item.ImageUrl) ? "results__card-link--no-image" : null)"
                           href="@item.Url"
                           target="_blank"
                           rel="noopener noreferrer">
                            @if (!string.IsNullOrWhiteSpace(item.ImageUrl))
                            {
                                <span class="results__card-media">
                                    <img src="@item.ImageUrl"
                                         alt=""
                                         loading="lazy"
                                         decoding="async"
                                         referrerpolicy="no-referrer-when-downgrade"
                                         width="160"
                                         height="105" />
                                </span>
                            }
                            <span class="results__card-text">
                                @if (item.PublishedAt is { } published)
                                {
                                    <span class="results__card-date">
                                        <time datetime="@published.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture)">@published.ToLocalTime().ToString("D", CultureInfo.CurrentCulture)</time>
                                    </span>
                                }
                                <span class="results__card-title">@item.Title</span>
                                <span class="results__card-meta">Read on funkysi1701.com <span class="results__card-arrow" aria-hidden="true">→</span></span>
                            </span>
                        </a>
                    </li>
                }
            </ul>
        </section>
    }
    else if (hasSearched && !isLoading && string.IsNullOrWhiteSpace(errorMessage))
    {
        <p class="message message--empty">No posts matched that query. Try different words or a broader topic.</p>
    }

    @if (hasSearched)
    {
        <footer class="tech-foot" aria-label="Technical details">
            <details class="tech-foot__details">
                <summary class="tech-foot__summary">How this search works (technical)</summary>
                <div class="tech-foot__body">
                    <p>
                        Results come from a vector index in Azure Cosmos DB for NoSQL (database <code>semantic-search-blog</code>),
                        populated by a small .NET indexer that reads the site’s RSS feed and stores OpenAI embedding vectors.
                        Your query is embedded the same way; closest vectors rank first — that is semantic search, not plain-text matching.
                    </p>
                </div>
            </details>
        </footer>
    }

    <footer class="site-built" aria-label="Site credits">
        Built by <a class="site-built__link" href="https://www.funkysi1701.com/" target="_blank" rel="noopener noreferrer">funkysi1701</a>
    </footer>
</main>

@code {
    private static readonly JsonSerializerOptions ApiJson = new(JsonSerializerDefaults.Web);
    private static readonly JsonSerializerOptions LdJsonOptions = new()
    {
        Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping,
    };

    private string _homePageTitle = string.Empty;
    private string _homeMetaDescription = string.Empty;
    private string _canonicalHomeUrl = string.Empty;
    private string _shareImageUrl = string.Empty;
    private string _shareImageAlt = string.Empty;
    private string _siteName = string.Empty;
    private string _jsonLdSiteName = string.Empty;
    private string _jsonLd = "{}";

    private ElementReference _queryInput;

    private string query = string.Empty;
    private bool isLoading;
    private bool hasSearched;
    private string? errorMessage;
    private readonly List<SearchResultItem> results = [];

    protected override void OnInitialized()
    {
        _homePageTitle = Configuration["Seo:Home:PageTitle"]?.Trim() ?? string.Empty;
        _homeMetaDescription = Configuration["Seo:Home:MetaDescription"]?.Trim() ?? string.Empty;
        var baseUrl = Configuration["Seo:CanonicalBaseUrl"]?.Trim().TrimEnd('/') ?? string.Empty;
        _canonicalHomeUrl = string.IsNullOrEmpty(baseUrl) ? string.Empty : $"{baseUrl}/";
        _shareImageUrl = string.IsNullOrEmpty(baseUrl) ? string.Empty : $"{baseUrl}/favicon.svg";
        _shareImageAlt = Configuration["Seo:ShareImageAlt"]?.Trim() ?? string.Empty;
        _siteName = Configuration["Seo:OgSiteName"]?.Trim() ?? string.Empty;
        _jsonLdSiteName = Configuration["Seo:JsonLdSiteName"]?.Trim() ?? string.Empty;

        var ld = new Dictionary<string, string>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "WebSite",
            ["name"] = _jsonLdSiteName,
            ["url"] = _canonicalHomeUrl,
            ["description"] = _homeMetaDescription,
        };
        _jsonLd = JsonSerializer.Serialize(ld, LdJsonOptions);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await _queryInput.FocusAsync();
        }
    }

    private async Task SearchAsync()
    {
        errorMessage = null;
        results.Clear();

        if (string.IsNullOrWhiteSpace(query))
        {
            errorMessage = "Enter a search query.";
            return;
        }

        isLoading = true;
        hasSearched = true;
        await InvokeAsync(StateHasChanged);
        try
        {
            var maxResults = GetConfiguredSearchMaxResults();
            var response = await Http.PostAsJsonAsync(
                "api/search",
                new SearchRequest(query.Trim(), maxResults),
                ApiJson);
            if (!response.IsSuccessStatusCode)
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = string.IsNullOrWhiteSpace(body)
                    ? $"Search failed ({(int)response.StatusCode})."
                    : body;
                return;
            }

            var list = await response.Content.ReadFromJsonAsync<List<SearchResultItem>>(ApiJson);
            if (list is { Count: > 0 })
            {
                results.AddRange(list);
            }
        }
        catch (HttpRequestException ex)
        {
            errorMessage =
                "Could not reach the search API. Run SemanticSearch.Api locally (see code README) or set ApiBaseUrl in appsettings.";
            if (!string.IsNullOrEmpty(ex.Message))
            {
                errorMessage += " " + ex.Message;
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private sealed record SearchRequest(string Query, int MaxResults);

    /// <summary>API allows 1–50; default from <c>Search:MaxResults</c> in wwwroot appsettings.</summary>
    private int GetConfiguredSearchMaxResults()
    {
        const int defaultValue = 30;
        var raw = Configuration["Search:MaxResults"];
        if (!int.TryParse(raw, out var v))
        {
            return defaultValue;
        }

        return Math.Clamp(v, 1, 50);
    }

    private sealed record SearchResultItem(
        string Id,
        string Title,
        string Url,
        string? ImageUrl = null,
        DateTimeOffset? PublishedAt = null);
}
